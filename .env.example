# MedLit Research 配置文件
# 复制此文件为 .env 并填入真实值

## API Keys
export EMBASE_API_KEY="your_embase_api_key_here"

## NCBI E-utilities 配置 (PubMed)
# 建议设置邮箱以遵守使用条款
export NCBI_EMAIL="your_email@example.com"

## 默认检索设置
export MEDLIT_DEFAULT_MAX_RESULTS=20
export MEDLIT_DEFAULT_DATE_RANGE="2020:2025"

## 工作目录
export MEDLIT_WORK_DIR="$HOME/.openclaw/workspace/medlit-research"

## 缓存目录
export MEDLIT_CACHE_DIR="$MEDLIT_WORK_DIR/cache"

## 全文存储目录
export MEDLIT_FULLTEXT_DIR="$MEDLIT_WORK_DIR/fulltexts"
